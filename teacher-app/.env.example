# ================================================================
# Supabase
# ================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ================================================================
# Cloudflare R2 - TEMP bucket (raw MP4 uploads)
# ================================================================
R2_TEMP_ACCOUNT_ID=your-cloudflare-account-id
R2_TEMP_ACCESS_KEY_ID=your-r2-access-key
R2_TEMP_SECRET_ACCESS_KEY=your-r2-secret-key
R2_TEMP_BUCKET_NAME=course-videos-temp
R2_TEMP_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ================================================================
# Cloudflare R2 - PROD bucket (HLS segments + thumbnails)
# ================================================================
R2_PROD_ACCESS_KEY_ID=your-r2-prod-access-key
R2_PROD_SECRET_ACCESS_KEY=your-r2-prod-secret-key
R2_PROD_BUCKET_NAME=course-videos-prod
R2_PROD_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ================================================================
# Redis (BullMQ)
# ================================================================
REDIS_URL=redis://localhost:6379
# For Railway/Upstash:
# REDIS_URL=redis://default:password@host:port

# ================================================================
# App
# ================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-min-32-chars

# ================================================================
# Rate Limiting (optional - Upstash Redis)
# ================================================================
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
